{
  "name": "atlas",
  "version": "1.0.0",
  "description": "AI writing agent with evaluator feedback loop",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && node scripts/copy-agent-prompts.mjs",
    "check": "npm run type-check && npm run test:assistant",
    "dev": "node --watch --import tsx src/index.ts",
    "start": "node dist/index.js",
    "smoke": "node --import tsx src/index.ts --dry-run --prompt \"Explain the assistant workflow in this project.\"",
    "smoke:build": "npm run build && node dist/index.js --dry-run --prompt \"Explain the assistant workflow in this project.\"",
    "smoke:save": "node --import tsx scripts/save-assistant-smoke-response.ts",
    "writer": "node --import tsx src/index.ts",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:assistant": "vitest run tests/assistant",
    "test:assistant:response": "vitest run tests/assistant/run-assistant.test.ts",
    "test:assistant:watch": "vitest tests/assistant",
    "ui:dev": "npm --prefix ui run dev",
    "ui:build": "npm --prefix ui run build",
    "ui:preview": "npm --prefix ui run preview"
  },
  "dependencies": {
    "@langchain/anthropic": "^0.3.34",
    "@langchain/core": "^0.3.0",
    "@langchain/langgraph": "^0.2.0",
    "@langchain/openai": "^0.2.0",
    "commander": "^12.0.0",
    "dotenv": "^16.4.5",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "prettier": "^3.8.1",
    "tsx": "^4.7.0",
    "typescript": "^5.5.0",
    "vitest": "^4.0.18"
  }
}
