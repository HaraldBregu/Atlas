{
  "name": "atlas",
  "version": "1.0.0",
  "description": "TypeScript AI application with tools, skills, and MCP",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "node --watch --import tsx src/index.ts",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "mcp:server": "node --import tsx src/mcp/server/index.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "openai": "^4.104.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.5.0"
  }
}
